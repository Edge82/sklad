# ===== BACKEND КОНФИГУРАЦИЯ =====

# Порт бэкенда сервера
BACKEND_PORT=8000

# JWT Secret (для подписи токенов)
JWT_SECRET=your-super-secret-key-change-in-production

# ===== 1C OData API =====

# Базовый URL к 1С OData API (для бэкенда)
# Полный путь с /odata/standard.odata/ чтобы потом просто добавлять endpoint
ONEC_BASE_URL=https://msk1.1cfresh.com/a/sbm/3784912/odata/standard.odata
ONEC_LOGIN=odata.user
ONEC_PASSWORD=HoroshkoUserSklad

# Базовый URL к 1С для Vite proxy (фронт-сервер)
VITE_1C_PROXY_TARGET=https://msk1.1cfresh.com

# Базовый URL к 1С OData API (для фронта - VITE переменные)
VITE_1C_BASE_URL=https://msk1.1cfresh.com/a/sbm/3784912/odata/standard.odata
VITE_1C_USERNAME=odata.user
VITE_1C_PASSWORD=HoroshkoUserSklad
VITE_1C_WAREHOUSE_GUID=344cfb30-e233-11f0-862e-fa163e5c9fa8

# GUID склада в 1С
WAREHOUSE_GUID=344cfb30-e233-11f0-862e-fa163e5c9fa8

# ===== FRONTEND КОНФИГУРАЦИЯ =====

# Порт фронтенда (для Vite dev server)
VITE_PORT=3000

# Базовый URL для API запросов
API_BASE_URL=http://localhost:8000

# ===== NODE ENVIRONMENT =====

NODE_ENV=development
